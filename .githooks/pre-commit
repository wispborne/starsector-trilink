#!/bin/sh
#
# Stamp build-info.js with the version being committed, then stage it so it
# rides along in this commit. Runs via Git's bundled sh (works on Windows too).
#
# Enable once per clone:  git config core.hooksPath .githooks
#
# `version` = number of commits including this one (git can't know a commit's
# own hash before it exists, so `hash` is the current HEAD — the commit this
# build is made on top of).

# Count existing commits; +1 for the commit about to be created. `|| echo 0`
# covers the very first commit, where HEAD doesn't resolve yet.
prev=$(git rev-list --count HEAD 2>/dev/null || echo 0)
version=$((prev + 1))
hash=$(git rev-parse --short HEAD 2>/dev/null || echo "0000000")
date=$(date +%Y-%m-%d)

cat > build-info.js <<EOF
/*
 * Auto-generated by .githooks/pre-commit — do NOT edit by hand.
 * \`version\` is the running commit count (ticks by one each commit); \`hash\` is
 * the commit this build sits on top of; \`date\` is when it was stamped.
 * Loaded as a plain global, same as config.js. See README "Version stamp".
 */
self.BUILD_INFO = { version: $version, hash: "$hash", date: "$date" };
EOF

git add build-info.js
